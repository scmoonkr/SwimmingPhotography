node_modules/
.env
dist/

# package-lock.json 은 커밋하지 않는다.
# Windows(개발)에서 만든 lock 이 Linux(서버)에서 네이티브 바이너리 설치를 막는
# npm optional-deps 버그(#4828)를 유발 → 각 환경에서 npm install 로 생성.
package-lock.json

# Nuxt 빌드 산출물
.nuxt/
.output/

# 옛 정적본 백업 (사용 안 함, 6GB 원본 이미지 포함) — 커밋 제외
client/ppppp/

# 디자인 원본의 대용량 이미지 (원본 40~49MB 다수) — 코드/프로토타입만 커밋, 원본은 제외
docs/html/images/temp/
docs/html/images/*.bak
